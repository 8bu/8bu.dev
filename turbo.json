{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "test:ssg": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "test/**",
        "scripts/**",
        "public/og/**",
        "vite.config.ts",
        "vitest.ssg.config.ts"
      ],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
